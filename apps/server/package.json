{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "dotenv": "catalog:",
    "elysia": "^1.4.28",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "@portfolio/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/nodemailer": "^6.4.17",
    "tsdown": "^0.21.9",
    "typescript": "catalog:"
  }
}
