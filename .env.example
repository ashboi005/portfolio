# ============================================================
# ASHWATH.SYS — environment variables
# Copy to .env and fill in. Site content lives in
# apps/web/src/content/content.json (no DB needed).
# ============================================================

# ---- Backend API (apps/server) ----
# Port the Elysia server listens on.
PORT=3000

# Comma-separated origins allowed to call the API (your frontend URL).
# Local dev: http://localhost:3001 · Prod: https://your-site.com
CORS_ORIGIN=http://localhost:3001

# Gmail SMTP for the contact form — it emails form submissions to you.
# IMPORTANT: use a Gmail *App Password*, NOT your normal password:
#   Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your16charapppassword

# Where contact submissions are delivered. Optional — defaults to GMAIL_USER.
CONTACT_TO=you@gmail.com

# ---- AutoSage RAG chat (the 🤓 chatbot + terminal `chat` command) ----
# Base URL of the AutoSage API, no trailing slash. The server proxies
# /api/v1/chat to ${AUTOSAGE_BASE_URL}/api/v1/chats/… so the key stays private.
AUTOSAGE_BASE_URL=https://your-autosage-host
AUTOSAGE_TENANT_ID=your-tenant-uuid
AUTOSAGE_KB_ID=your-knowledge-base-uuid
AUTOSAGE_API_KEY=your-api-key

# ---- Frontend (apps/web) ----
# Base URL of the backend API the contact form POSTs to.
# Local dev: http://localhost:3000 · Prod: https://api.your-site.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
